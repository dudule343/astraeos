NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role (server-side only) — bypasse RLS pour les API routes.
SUPABASE_SERVICE_ROLE_KEY=

# Qonto Business API
# Value to pass verbatim as the Authorization header.
# Two supported formats:
#   - Static API key (Basic-ish):  organization-slug:secret-key
#   - OAuth bearer token:          Bearer <access_token>
# Generate from https://app.qonto.com (Settings -> Business API).
QONTO_AUTH=

# ──────────────────────────────────────────────────────────────────────
# Google Calendar OAuth 2.0
# Crée un OAuth Client (type "Web application") dans Google Cloud Console :
#   1. https://console.cloud.google.com → créer un projet "Astraeos"
#   2. APIs & Services → Library → activer "Google Calendar API"
#   3. APIs & Services → Credentials → Create OAuth client ID
#      - Application type : Web application
#      - Authorized JavaScript origins :
#          https://astraeos.vercel.app
#          http://localhost:3000
#      - Authorized redirect URIs :
#          https://astraeos.vercel.app/api/auth/google/callback
#          http://localhost:3000/api/auth/google/callback
#   4. OAuth consent screen → External → publier ou ajouter testeurs
#   5. Coller Client ID et Client Secret ci-dessous
#
# Tant que ces 3 vars sont vides, le bouton "Connecter Google Calendar"
# tombe sur le mode démo (popup look-alike, aucun vrai token).
# Guide détaillé : ~/Downloads/Astraeos-Google-OAuth-Setup.md
# ──────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
