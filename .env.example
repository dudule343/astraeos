NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Qonto Business API
# Value to pass verbatim as the Authorization header.
# Two supported formats:
#   - Static API key (Basic-ish):  organization-slug:secret-key
#   - OAuth bearer token:          Bearer <access_token>
# Generate from https://app.qonto.com (Settings -> Business API).
QONTO_AUTH=
